# Server
HOST=0.0.0.0
PORT=8000

# Camera backend selection: picamera2 or pypylon
CAMERA_BACKEND=picamera2

# Camera index for selected backend
CAMERA_NUM=0

# Stream configuration
STREAM_SIZE=1280x720
STREAM_FPS=30

# Optional picamera2 overrides
# CAMERA_SENSOR_MODEL=imx219
# CAMERA_TUNING_FILE=

# OpenMicroStage serial defaults
# Leave OMS_PORT empty to keep simulation mode until explicit connect.
OMS_PORT=
OMS_BAUD_RATE=921600
OMS_SHOW_COMMUNICATION=true
OMS_SHOW_LOG_MESSAGES=true
OMS_EXCEPTION_ON_NO_DEVICE=false
OMS_AUTO_CONNECT=false
# Optional runtime broadcast value for APIs that expose it
OMS_SERIAL_BROADCAST=
